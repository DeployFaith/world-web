{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deployfaith.github.io/world-web/schemas/registry.schema.json",
  "title": "World Web Registry",
  "type": "object",
  "required": ["version", "product", "default_domain", "sites"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "product": { "type": "string", "minLength": 1 },
    "default_domain": { "type": "string", "minLength": 1 },
    "sites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["domain", "title", "description", "root", "entry", "routes", "agent_visible"],
        "properties": {
          "domain": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "root": { "type": "string", "minLength": 1 },
          "entry": { "type": "string", "pattern": "^/" },
          "routes": {
            "type": "object",
            "propertyNames": { "pattern": "^/" },
            "additionalProperties": { "type": "string", "minLength": 1 }
          },
          "agent_visible": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
